# community_service 项目环境变量配置模板
# 复制此文件为 .env 并修改对应值

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./community_service.db

# AI 厂商选择: mock / openai / deepseek / hunyuan
AI_PROVIDER=mock

# OpenAI 配置（AI_PROVIDER=openai 时生效）
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# DeepSeek 配置（AI_PROVIDER=deepseek 时生效）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 混元配置（AI_PROVIDER=hunyuan 时生效）
HUNYUAN_SECRET_ID=your-secret-id
HUNYUAN_SECRET_KEY=your-secret-key
HUNYUAN_MODEL=hunyuan-lite

# 小米 MiMo 配置（AI_PROVIDER=mimo 时生效，兼容 OpenAI 协议）
# 前往 https://mimo.mi.com 控制台获取 API Key
MIMO_API_KEY=sk-your-mimo-key
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# ========== 业务阈值配置 ==========

# 信用分阈值：低于此分数自动触发黑名单审查
CREDIT_SCORE_THRESHOLD=30

# 投诉次数阈值：累计投诉超过此次数自动拉黑
COMPLAINT_COUNT_THRESHOLD=3

# 超时次数阈值：7天内超时订单超过此次数自动拉黑
TIMEOUT_COUNT_THRESHOLD=3

# 超时检测窗口（天）
TIMEOUT_WINDOW_DAYS=7

# 订单各阶段超时阈值（分钟）
ORDER_ACCEPT_TIMEOUT_MINUTES=30
ORDER_START_TIMEOUT_MINUTES=60
ORDER_FINISH_TIMEOUT_MINUTES=480
ORDER_CONFIRM_TIMEOUT_MINUTES=1440

# 派单引擎权重
DISPATCH_WEIGHT_CREDIT_SCORE=0.5
DISPATCH_WEIGHT_ONGOING_ORDERS=5.0
DISPATCH_WEIGHT_DISTANCE_MAX=20.0
DISPATCH_WEIGHT_SKILL_MATCH=10.0
DISPATCH_WEIGHT_TIMEOUT_PENALTY=5.0

# 信用分加减分规则
SCORE_QUICK_ACCEPT_BONUS=3
SCORE_COMPLAINT_PENALTY=-20
SCORE_TIMEOUT_PENALTY=-10
SCORE_GOOD_REVIEW_BONUS=5

# 居民评价权重
REVIEW_WEIGHT_RESIDENT=0.7
REVIEW_WEIGHT_PROVIDER=0.3
